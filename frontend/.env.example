# ========================================
# OPTIONAL - Only needed for Supabase
# ========================================

# Supabase - for user accounts and detection storage
# Comment out if not using Supabase (detections will use localStorage)
# Create free project: https://supabase.com/dashboard
# Get keys from: Project Settings → API
#VITE_SUPABASE_URL=https://your-project.supabase.co
#VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# API URL - uncomment if backend is on different host
# Default is relative path (works for local dev)
#VITE_API_URL=http://localhost:3001
