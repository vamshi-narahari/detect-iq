# AWS Bedrock (Claude AI) - REQUIRED
# Get AWS credentials: https://console.aws.amazon.com/iam/home#/security_credentials
# Enable Claude Sonnet 4.6: https://console.aws.amazon.com/bedrock/home#/modelaccess
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Redis - REQUIRED (for caching + BullMQ job queues)
# Install: sudo apt install redis-server (Ubuntu) or brew install redis (Mac)
REDIS_URL=redis://127.0.0.1:6379

# Supabase - OPTIONAL (needed for user accounts, team collaboration)
# Create project: https://supabase.com/dashboard
# Get keys from: Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Resend (email) - OPTIONAL (for password reset emails)
# Sign up: https://resend.com/signup
RESEND_API_KEY=your_resend_api_key

# CORS - OPTIONAL (comma-separated allowed origins)
# Leave empty to allow all origins in development
ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.com

# Server
PORT=3001
