# Prevent credential files from being accidentally committed
*.env filter=git-crypt diff=git-crypt
*.pem filter=git-crypt diff=git-crypt
*.key filter=git-crypt diff=git-crypt
*credentials* filter=git-crypt diff=git-crypt
*secret* filter=git-crypt diff=git-crypt

# Line ending normalization
* text=auto
*.sh text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
